# .dockerignore
# Python cache / build artefacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# VCS / IDE
.git/
.gitignore
.vscode/
.idea/
.github/

# Local runtime that is bind-mounted at runtime
local/
.env
*.sqlite
*.db

# Virtual environment (present in dev, excluded from build context)
.venv/
node_modules/

# Build/dist
build/
dist/

# Docs and config not needed at runtime
*.md
!README.md
LICENSE
Makefile
docker-compose.yaml
.editorconfig
.pre-commit-config.yaml